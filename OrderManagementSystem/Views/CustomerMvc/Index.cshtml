@model IEnumerable<OrderManagementSystem.Models.DTOs.CustomerDto>

@{
    ViewBag.Title = "Customers";
}

<style>
    .index-container {
        max-width: 960px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .index-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

        .index-header h2 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0;
        }

    .btn-add {
        padding: 9px 22px;
        border-radius: 8px;
        border: none;
        background: #28a745;
        color: #fff;
        font-size: 0.92rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.15s;
        display: inline-block;
    }

        .btn-add:hover {
            background: #218838;
            color: #fff;
            text-decoration: none;
        }

    .data-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.93rem;
    }

        .data-table thead tr {
            background: #f8fafc;
            border-bottom: 2px solid #e9ecef;
        }

        .data-table th {
            padding: 12px 16px;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .data-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background 0.12s;
        }

            .data-table tbody tr:last-child {
                border-bottom: none;
            }

            .data-table tbody tr:hover {
                background: #f9fafb;
            }

        .data-table td {
            padding: 13px 16px;
            color: #374151;
            vertical-align: middle;
        }

    .customer-avatar {
        display: inline-flex;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 700;
        align-items: center;
        justify-content: center;
        margin-right: 10px;
        vertical-align: middle;
        flex-shrink: 0;
    }

    .customer-name-cell {
        display: flex;
        align-items: center;
    }

    .email-text {
        color: #4b5563;
        font-size: 0.9rem;
    }

    .date-text {
        color: #9ca3af;
        font-size: 0.85rem;
    }

    .action-group {
        display: flex;
        gap: 6px;
    }

    .btn-tbl {
        padding: 5px 13px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: opacity 0.15s;
        border: none;
        cursor: pointer;
    }

        .btn-tbl:hover {
            opacity: 0.85;
            text-decoration: none;
        }

    .btn-edit {
        background: #fff3cd;
        color: #856404;
    }

    .btn-details {
        background: #cff4fc;
        color: #055160;
    }

    .btn-delete {
        background: #fee2e2;
        color: #dc2626;
    }

    .empty-state {
        padding: 48px 20px;
        text-align: center;
        color: #9ca3af;
        font-size: 0.95rem;
    }

        .empty-state .empty-icon {
            font-size: 2.5rem;
            margin-bottom: 12px;
        }
</style>

<div class="index-container">
    
    <div class="index-header">
        <h2>👥 Customers</h2>
        <a href="/CustomerMvc/Create" class="btn-add">+ Add Customer</a>
    </div>

    <div class="data-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Customer</th>
                    <th>Email</th>
                    <th>Member Since</th>
                    <th style="width:180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="customer-name-cell">
                                    <span class="customer-avatar">
                                        @item.Name.Substring(0, 1).ToUpper()
                                    </span>
                                    <strong>@item.Name</strong>
                                </div>
                            </td>
                            <td><span class="email-text">@item.Email</span></td>
                            <td><span class="date-text">@item.CreatedAt.ToString("dd MMM yyyy")</span></td>
                            <td>
                                <div class="action-group">
                                    @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn-tbl btn-edit" })
                                    @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn-tbl btn-details" })
                                    @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn-tbl btn-delete" })
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <div class="empty-icon">👥</div>
                                <div>No customers found</div>
                                <a href="/CustomerMvc/Create" style="color:#6366f1; font-weight:600;">Add your first customer →</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>