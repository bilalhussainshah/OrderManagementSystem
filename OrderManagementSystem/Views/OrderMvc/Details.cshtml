@model OrderManagementSystem.Models.DTOs.OrderDetailDto

@{
    ViewBag.Title = "Order Details";
    var total = Model.Items.Sum(i => i.Quantity * i.UnitPrice);
}

<style>
    .detail-card {
        max-width: 720px;
        margin: 48px auto;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.10);
        padding: 40px 48px 36px 48px;
    }

        .detail-card h2 {
            font-size: 1.7rem;
            font-weight: 700;
            text-align: center;
            color: #1a1a2e;
            margin-bottom: 6px;
        }

    .detail-section-header {
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 14px;
        margin-bottom: 24px;
        margin-top: 20px;
    }

        .detail-section-header h5 {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 3px;
            color: #333;
        }

        .detail-section-header p {
            font-size: 0.85rem;
            color: #888;
            margin: 0;
        }

    .order-icon-wrap {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        background: linear-gradient(135deg, #43e97b, #38f9d7);
        color: #fff;
        font-size: 1.8rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px auto;
    }

    .order-meta-strip {
        display: flex;
        gap: 16px;
        margin-bottom: 28px;
    }

    .meta-tile {
        flex: 1;
        background: #f8fafc;
        border: 1px solid #e9ecef;
        border-radius: 10px;
        padding: 14px 18px;
    }

        .meta-tile .meta-label {
            font-size: 0.72rem;
            font-weight: 600;
            color: #9ca3af;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 5px;
        }

        .meta-tile .meta-value {
            font-size: 0.97rem;
            font-weight: 600;
            color: #1f2937;
        }

    .items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.93rem;
    }

        .items-table thead tr {
            background: #f8fafc;
            border-bottom: 2px solid #e9ecef;
        }

        .items-table th {
            padding: 11px 14px;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

            .items-table th:last-child,
            .items-table td:last-child {
                text-align: right;
            }

        .items-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background 0.12s;
        }

            .items-table tbody tr:last-child {
                border-bottom: none;
            }

            .items-table tbody tr:hover {
                background: #fafafa;
            }

        .items-table td {
            padding: 13px 14px;
            color: #374151;
            vertical-align: middle;
        }

    .product-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #6366f1;
        margin-right: 8px;
        vertical-align: middle;
    }

    .qty-chip {
        display: inline-block;
        background: #ede9fe;
        color: #5b21b6;
        border-radius: 20px;
        padding: 2px 10px;
        font-size: 0.82rem;
        font-weight: 600;
    }

    .total-row {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 16px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 2px solid #e9ecef;
    }

    .total-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .total-amount {
        font-size: 1.25rem;
        font-weight: 700;
        color: #16a34a;
    }

    .detail-actions {
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #f0f0f0;
    }

    .btn-back {
        padding: 10px 26px;
        border-radius: 7px;
        border: 1.5px solid #ccc;
        background: #fff;
        color: #555;
        font-size: 0.93rem;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        display: inline-block;
    }

        .btn-back:hover {
            background: #f5f5f5;
            border-color: #aaa;
            color: #333;
            text-decoration: none;
        }
</style>

<div class="detail-card">

    <div class="order-icon-wrap">🧾</div>

    <h2>Order #@Model.Id</h2>

    <div class="detail-section-header">
        <h5>Order Summary</h5>
        <p>Full breakdown of this order</p>
    </div>

    <!-- Meta strip -->
    <div class="order-meta-strip">
        <div class="meta-tile">
            <div class="meta-label">Order ID</div>
            <div class="meta-value">#@Model.Id</div>
        </div>
        <div class="meta-tile">
            <div class="meta-label">Customer</div>
            <div class="meta-value">@Model.CustomerName</div>
        </div>
        <div class="meta-tile">
            <div class="meta-label">Order Date</div>
            <div class="meta-value">@Model.OrderDate.ToString("dd MMM yyyy")</div>
        </div>
        <div class="meta-tile">
            <div class="meta-label">Items</div>
            <div class="meta-value">@Model.Items.Count product@(Model.Items.Count == 1 ? "" : "s")</div>
        </div>
    </div>

    <!-- Items table -->
    <table class="items-table">
        <thead>
            <tr>
                <th>Product</th>
                <th style="text-align:center;">Qty</th>
                <th>Unit Price</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>
                        <span class="product-dot"></span>
                        @item.ProductName
                    </td>
                    <td style="text-align:center;">
                        <span class="qty-chip">@item.Quantity</span>
                    </td>
                    <td>€ @item.UnitPrice.ToString("F2")</td>
                    <td>€ @((item.Quantity * item.UnitPrice).ToString("F2"))</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Total -->
    <div class="total-row">
        <span class="total-label">Order Total</span>
        <span class="total-amount">€ @total.ToString("F2")</span>
    </div>

    <div class="detail-actions">
        <a href="/OrderMvc" class="btn-back">← Back to Orders</a>
    </div>

</div>