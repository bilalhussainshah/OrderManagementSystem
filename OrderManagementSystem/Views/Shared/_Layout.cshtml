<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Order Management System</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <!-- Toastr -->
    <link href="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f4f6f9;
            padding-top: 70px;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.2rem;
            letter-spacing: 0.02em;
        }

        .main-content {
            min-height: calc(100vh - 130px);
        }

        footer {
            background: #fff;
            border-top: 1px solid #e9ecef;
            padding: 16px 0;
            text-align: center;
            color: #888;
            font-size: 0.85rem;
        }

        /* Toast position override */
        #toast-container > .toast {
            border-radius: 8px;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow-sm">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">
                <i class="bi bi-box-seam me-2"></i>Order Management
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "CustomerMvc" ? "active" : "")"
                           href="@Url.Action("Index", "CustomerMvc")">
                            <i class="bi bi-people me-1"></i>Customers
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ProductMvc" ? "active" : "")"
                           href="@Url.Action("Index", "ProductMvc")">
                            <i class="bi bi-box me-1"></i>Products
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "OrderMvc" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           href="@Url.Action("Index", "OrderMvc")">
                            <i class="bi bi-receipt me-1"></i>Orders
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-primary text-white ms-2 px-3"
                           href="@Url.Action("Create", "OrderMvc")">
                            <i class="bi bi-plus-circle me-1"></i>New Order
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container main-content py-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            &copy; @DateTime.Now.Year Order Management System
        </div>
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery (for jqueryval) -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <!-- jQuery Validate -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <!-- Toastr -->
    <script src="https://cdn.jsdelivr.net/npm/toastr@2.1.4/build/toastr.min.js"></script>

    <script>
        toastr.options = {
            positionClass: "toast-top-right",
            timeOut: 4000,
            closeButton: true,
            progressBar: true
        };

        @if (TempData["Success"] != null)
        {
            <text>toastr.success("@Html.Raw(TempData["Success"])");</text>
        }
        @if (TempData["Error"] != null)
        {
            <text>toastr.error("@Html.Raw(TempData["Error"])");</text>
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
